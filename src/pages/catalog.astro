---
import Layout from '../layouts/Base.astro';
import catalog from '../data/catalog.json';

const categoryNames: Record<string, string> = {
  'fundamental-mechanism': 'Fundamental Mechanism',
  'materials-design': 'Materials Design',
  'application': 'Application',
  'review-perspective': 'Review & Perspective',
  'review': 'Review',
  'computational': 'Computational',
};

const categoryCounts: Record<string, number> = {};
catalog.forEach(paper => {
  const displayCat = categoryNames[paper.category] || paper.category;
  categoryCounts[displayCat] = (categoryCounts[displayCat] || 0) + 1;
});

const journals = new Set(catalog.map(p => p.journal).filter(Boolean));

const sortedPapers = [...catalog].sort((a, b) =>
  new Date(b.date + 'T12:00:00').getTime() - new Date(a.date + 'T12:00:00').getTime()
);
---

<Layout
  title="Research Catalog"
  description={`Browse ${catalog.length} curated papers on Triplet-Triplet Annihilation Upconversion across ${journals.size} journals.`}
  currentPath="/catalog"
>

  <div class="max-w-7xl mx-auto px-6">

    <section class="pt-16 sm:pt-20 pb-10">
      <h1 class="text-3xl font-bold tracking-tight text-[var(--color-text-primary)] leading-tight mb-3">
        Research Catalog
      </h1>
      <p class="text-[var(--color-text-tertiary)] text-sm">
        {catalog.length} papers across {journals.size} journals and {Object.keys(categoryCounts).length} categories.
      </p>
    </section>

    <!-- Search and filter -->
    <section class="pb-8" role="search" aria-label="Filter papers">
      <div class="flex flex-col sm:flex-row gap-3">
        <div class="relative flex-1">
          <svg class="absolute left-3.5 top-1/2 -translate-y-1/2 w-4 h-4 text-[var(--color-text-tertiary)]" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M21 21l-5.197-5.197m0 0A7.5 7.5 0 105.196 5.196a7.5 7.5 0 0010.607 10.607z" />
          </svg>
          <input
            type="text"
            id="searchBox"
            placeholder="Search by title, author, journal..."
            aria-label="Search papers by title, author, or journal"
            class="w-full pl-10 pr-4 py-2.5 bg-[var(--color-surface-1)] border border-[var(--color-border-subtle)] rounded-lg text-sm text-[var(--color-text-primary)] placeholder:text-[var(--color-text-tertiary)]"
          />
        </div>
        <select
          id="categoryFilter"
          aria-label="Filter by category"
          class="px-4 py-2.5 bg-[var(--color-surface-1)] border border-[var(--color-border-subtle)] rounded-lg text-sm text-[var(--color-text-secondary)] appearance-none cursor-pointer min-w-[180px]"
        >
          <option value="all">All categories</option>
          {Object.keys(categoryCounts).sort().map(cat => (
            <option value={cat}>{cat} ({categoryCounts[cat]})</option>
          ))}
        </select>
      </div>
    </section>

    <!-- Papers list -->
    <section class="pb-24">
      <div id="papersContainer" class="divide-y divide-[var(--color-border-subtle)]">
        {sortedPapers.map(paper => {
          const displayCat = categoryNames[paper.category] || paper.category;
          return (
            <div
              class="paper-item py-6 first:pt-0"
              data-paper={JSON.stringify(paper)}
              data-category={displayCat}
            >
              <div class="flex items-start justify-between gap-4 mb-2">
                <a
                  href={paper.url || '#'}
                  target="_blank"
                  rel="noopener"
                  class="text-[var(--color-text-primary)] hover:text-[var(--color-accent-hover)] transition-colors font-medium leading-snug flex-1"
                >
                  {paper.title}
                </a>
                {(paper.significance === 'very-high' || paper.significance === 'high') && (
                  <span class:list={[
                    'shrink-0 text-xs mt-0.5',
                    paper.significance === 'very-high'
                      ? 'text-[var(--color-text-secondary)]'
                      : 'text-[var(--color-text-tertiary)]',
                  ]}>
                    {paper.significance === 'very-high' ? 'High impact' : 'Notable'}
                  </span>
                )}
              </div>

              <div class="flex flex-wrap items-center gap-x-2 gap-y-1 text-sm text-[var(--color-text-tertiary)] mb-3">
                <span class="truncate max-w-sm">
                  {paper.authors.slice(0, 3).join(', ')}{paper.authors.length > 3 ? ' et al.' : ''}
                </span>
                {paper.journal && (
                  <>
                    <span class="text-[var(--color-border-default)]">/</span>
                    <span>{paper.journal}</span>
                  </>
                )}
                <span class="text-[var(--color-border-default)]">/</span>
                <time>
                  {new Date(paper.date + 'T12:00:00').toLocaleDateString('en-US', { year: 'numeric', month: 'short' })}
                </time>
                <span class="text-[var(--color-border-default)]">/</span>
                <span>{displayCat}</span>
              </div>

              <p class="text-sm text-[var(--color-text-secondary)] leading-relaxed mb-3">
                {paper.abstract_summary}
              </p>

              {paper.significance_notes && (
                <p class="text-sm text-[var(--color-text-tertiary)] leading-relaxed">
                  {paper.significance_notes}
                </p>
              )}
            </div>
          );
        })}
      </div>

      <div id="noResults" class="hidden py-16 text-center">
        <p class="text-[var(--color-text-tertiary)]">No papers match your search.</p>
      </div>
    </section>

  </div>

  <script is:inline define:vars={{ categoryNames }}>
    const searchBox = document.getElementById('searchBox');
    const categoryFilter = document.getElementById('categoryFilter');

    const urlParams = new URLSearchParams(window.location.search);
    const initialCategory = urlParams.get('category');
    if (initialCategory) {
      categoryFilter.value = initialCategory;
      filterPapers();
    }

    function filterPapers() {
      const searchTerm = searchBox.value.toLowerCase();
      const selectedCategory = categoryFilter.value;
      const items = document.querySelectorAll('.paper-item');
      let visibleCount = 0;

      items.forEach(item => {
        const paperData = JSON.parse(item.getAttribute('data-paper') || '{}');
        const displayCat = categoryNames[paperData.category] || paperData.category;

        const matchesCategory = selectedCategory === 'all' || displayCat === selectedCategory;
        const matchesSearch = !searchTerm ||
          paperData.title.toLowerCase().includes(searchTerm) ||
          paperData.authors.some(a => a.toLowerCase().includes(searchTerm)) ||
          paperData.abstract_summary.toLowerCase().includes(searchTerm) ||
          (paperData.significance_notes || '').toLowerCase().includes(searchTerm) ||
          (paperData.journal || '').toLowerCase().includes(searchTerm) ||
          (paperData.tags || []).some(t => t.toLowerCase().includes(searchTerm));

        if (matchesCategory && matchesSearch) {
          item.classList.remove('hidden');
          visibleCount++;
        } else {
          item.classList.add('hidden');
        }
      });

      const noResults = document.getElementById('noResults');
      noResults.classList.toggle('hidden', visibleCount > 0);
    }

    searchBox.addEventListener('input', filterPapers);
    categoryFilter.addEventListener('change', filterPapers);
  </script>
</Layout>
