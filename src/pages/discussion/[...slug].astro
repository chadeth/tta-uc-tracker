---
import Layout from '../../layouts/Base.astro';
import { getCollection, render as renderEntry } from 'astro:content';

export async function getStaticPaths() {
  const articles = await getCollection('articles');
  return articles.map(article => ({
    params: { slug: article.id },
    props: { article },
  }));
}

const { article } = Astro.props;
const { Content } = await renderEntry(article);

const dateObj = new Date(article.data.date + 'T12:00:00');
const formattedDate = dateObj.toLocaleDateString('en-US', {
  year: 'numeric',
  month: 'long',
  day: 'numeric',
  weekday: 'long'
});

// Get all articles for prev/next navigation
const allArticles = await getCollection('articles');
const sorted = allArticles.sort((a, b) =>
  new Date(b.data.date + 'T12:00:00').getTime() - new Date(a.data.date + 'T12:00:00').getTime()
);
const currentIndex = sorted.findIndex(a => a.id === article.id);
const prevArticle = currentIndex < sorted.length - 1 ? sorted[currentIndex + 1] : null;
const nextArticle = currentIndex > 0 ? sorted[currentIndex - 1] : null;
---

<Layout
  title={article.data.title}
  description={`${article.data.title}. Expert commentary and analysis on TTA-UC research developments.`}
  currentPath={`/discussion/${article.id}`}
>

  <!-- Article Header -->
  <div class="border-b border-[var(--color-border-subtle)] bg-gradient-to-b from-[var(--color-surface-1)] to-[var(--color-surface-0)]">
    <div class="max-w-4xl mx-auto px-6 pt-16 sm:pt-20 pb-12">
      <div class="animate-fade-in">
        <!-- Breadcrumb -->
        <div class="flex items-center gap-2 mb-8 text-xs">
          <a href="/discussion" class="text-[var(--color-text-tertiary)] hover:text-[var(--color-text-secondary)] transition-colors duration-200">Discussion</a>
          <svg class="w-3 h-3 text-[var(--color-border-default)]" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5l7 7-7 7" /></svg>
          <span class="text-[var(--color-text-tertiary)]">{article.data.date}</span>
        </div>

        {article.data.edition && (
          <span class="inline-block text-xs text-[var(--color-accent-hover)] font-semibold mb-4">{article.data.edition}</span>
        )}

        <h1 class="text-3xl sm:text-4xl font-bold tracking-tight text-[var(--color-text-primary)] leading-tight mb-6">
          {article.data.title}
        </h1>

        <div class="flex items-center gap-4">
          <time class="text-sm text-[var(--color-text-tertiary)]">{formattedDate}</time>
        </div>
      </div>
    </div>
  </div>

  <!-- Article Body -->
  <article class="max-w-4xl mx-auto px-6 py-12 sm:py-16 animate-fade-in" style="animation-delay: 0.1s">
    <div class="prose prose-lg max-w-none prose-headings:scroll-mt-20">
      <Content />
    </div>
  </article>

  <!-- Article Navigation -->
  <div class="border-t border-[var(--color-border-subtle)]">
    <div class="max-w-4xl mx-auto px-6 py-12">
      <div class="flex flex-col sm:flex-row gap-4">
        {prevArticle ? (
          <a href={`/discussion/${prevArticle.id}`} class="flex-1 group rounded-xl border border-[var(--color-border-subtle)] bg-[var(--color-surface-1)] p-6 hover:border-[var(--color-border-default)] transition-all duration-200">
            <span class="text-xs text-[var(--color-text-tertiary)] uppercase tracking-wider">Previous</span>
            <p class="text-sm font-semibold text-[var(--color-text-primary)] group-hover:text-[var(--color-accent-hover)] transition-colors duration-200 mt-2">{prevArticle.data.title}</p>
          </a>
        ) : <div class="flex-1" />}

        {nextArticle ? (
          <a href={`/discussion/${nextArticle.id}`} class="flex-1 group rounded-xl border border-[var(--color-border-subtle)] bg-[var(--color-surface-1)] p-6 hover:border-[var(--color-border-default)] transition-all duration-200 text-right">
            <span class="text-xs text-[var(--color-text-tertiary)] uppercase tracking-wider">Next</span>
            <p class="text-sm font-semibold text-[var(--color-text-primary)] group-hover:text-[var(--color-accent-hover)] transition-colors duration-200 mt-2">{nextArticle.data.title}</p>
          </a>
        ) : <div class="flex-1" />}
      </div>

      <div class="text-center mt-8">
        <a href="/discussion" class="inline-flex items-center gap-2 text-sm text-[var(--color-text-tertiary)] hover:text-[var(--color-accent-hover)] transition-colors duration-200">
          <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M7 16l-4-4m0 0l4-4m-4 4h18" /></svg>
          All discussions
        </a>
      </div>
    </div>
  </div>

</Layout>
