---
import '../styles/global.css';

interface Props {
  title?: string;
  description?: string;
  currentPath?: string;
}

const {
  title = 'TTA-UC Research Tracker',
  description = 'Tracking and analyzing research on Triplet-Triplet Annihilation Upconversion. Curated catalog and expert commentary for the photochemistry community.',
  currentPath = '/',
} = Astro.props;

const fullTitle = title === 'TTA-UC Research Tracker' ? title : `${title} - TTA-UC Research Tracker`;

const navLinks = [
  { href: '/', label: 'Home' },
  { href: '/catalog', label: 'Catalog' },
  { href: '/discussion', label: 'Discussion' },
  { href: '/about', label: 'About' },
];

function isActive(href: string, current: string): boolean {
  if (href === '/') return current === '/';
  return current.startsWith(href);
}
---

<!DOCTYPE html>
<html lang="en" class="dark">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>{fullTitle}</title>
  <meta name="description" content={description}>
  <link rel="icon" href="/favicon.svg" type="image/svg+xml">
  <link rel="icon" href="/favicon.ico" sizes="32x32">
  <link rel="alternate" type="application/rss+xml" title="TTA-UC Research Tracker" href="/rss.xml">
  <link rel="canonical" href={`https://tta-uc-tracker.pages.dev${currentPath}`}>

  <meta property="og:type" content="website">
  <meta property="og:title" content={fullTitle}>
  <meta property="og:description" content={description}>
  <meta property="og:site_name" content="TTA-UC Research Tracker">
  <meta property="og:url" content={`https://tta-uc-tracker.pages.dev${currentPath}`}>

  <meta name="twitter:card" content="summary">
  <meta name="twitter:title" content={fullTitle}>
  <meta name="twitter:description" content={description}>

  <slot name="head" />
</head>
<body class="bg-[var(--color-surface-0)] text-[var(--color-text-secondary)] font-sans antialiased min-h-screen flex flex-col">

  <a href="#main-content" class="skip-to-content">Skip to main content</a>

  <nav class="border-b border-[var(--color-border-subtle)]" aria-label="Main navigation">
    <div class="max-w-7xl mx-auto px-6 h-14 flex items-center justify-between">
      <a href="/" class="text-sm font-semibold text-[var(--color-text-primary)] tracking-tight">
        TTA-UC Research
      </a>

      <div class="hidden sm:flex items-center gap-8">
        {navLinks.map(link => (
          <a
            href={link.href}
            class:list={[
              'text-sm transition-colors duration-150',
              isActive(link.href, currentPath)
                ? 'text-[var(--color-text-primary)]'
                : 'text-[var(--color-text-tertiary)] hover:text-[var(--color-text-secondary)]',
            ]}
          >
            {link.label}
          </a>
        ))}
      </div>

      <button
        id="mobileMenuBtn"
        class="sm:hidden p-2 -mr-2 text-[var(--color-text-tertiary)]"
        aria-label="Toggle navigation menu"
        aria-expanded="false"
        aria-controls="mobileMenu"
      >
        <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
          <path id="menuIcon" stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M4 6h16M4 12h16M4 18h16" />
        </svg>
      </button>
    </div>

    <div id="mobileMenu" class="hidden sm:hidden border-t border-[var(--color-border-subtle)]">
      <div class="max-w-7xl mx-auto px-6 py-3 flex flex-col gap-1">
        {navLinks.map(link => (
          <a
            href={link.href}
            class:list={[
              'py-2 text-sm',
              isActive(link.href, currentPath)
                ? 'text-[var(--color-text-primary)]'
                : 'text-[var(--color-text-tertiary)]',
            ]}
          >
            {link.label}
          </a>
        ))}
      </div>
    </div>
  </nav>

  <main id="main-content" class="flex-1" tabindex="-1">
    <slot />
  </main>

  <footer class="border-t border-[var(--color-border-subtle)]">
    <div class="max-w-7xl mx-auto px-6 py-6 flex flex-col sm:flex-row items-center justify-between gap-2 text-xs text-[var(--color-text-tertiary)]">
      <span>Copyright 2026 TTA-UC Research Tracker</span>
      <div class="flex gap-6">
        <a href="/catalog" class="hover:text-[var(--color-text-secondary)] transition-colors">Catalog</a>
        <a href="/discussion" class="hover:text-[var(--color-text-secondary)] transition-colors">Discussion</a>
        <a href="/about" class="hover:text-[var(--color-text-secondary)] transition-colors">About</a>
        <a href="/rss.xml" class="hover:text-[var(--color-text-secondary)] transition-colors flex items-center gap-1" title="RSS Feed">
          <svg class="w-3.5 h-3.5" viewBox="0 0 24 24" fill="currentColor"><circle cx="6.18" cy="17.82" r="2.18"/><path d="M4 4.44v2.83c7.03 0 12.73 5.7 12.73 12.73h2.83c0-8.59-6.97-15.56-15.56-15.56zm0 5.66v2.83c3.9 0 7.07 3.17 7.07 7.07h2.83c0-5.47-4.43-9.9-9.9-9.9z"/></svg>
          RSS
        </a>
      </div>
    </div>
  </footer>

  <!-- Back to top button -->
  <button
    id="backToTop"
    class="fixed bottom-6 right-6 z-50 p-2.5 rounded-full bg-[var(--color-surface-2)] border border-[var(--color-border-subtle)] text-[var(--color-text-tertiary)] hover:text-[var(--color-text-secondary)] hover:border-[var(--color-border-default)] transition-all duration-200 opacity-0 translate-y-4 pointer-events-none"
    aria-label="Back to top"
  >
    <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24" stroke-width="2">
      <path stroke-linecap="round" stroke-linejoin="round" d="M5 15l7-7 7 7" />
    </svg>
  </button>

  <script is:inline>
    const menuBtn = document.getElementById('mobileMenuBtn');
    const mobileMenu = document.getElementById('mobileMenu');
    if (menuBtn && mobileMenu) {
      menuBtn.addEventListener('click', () => {
        const isOpen = !mobileMenu.classList.toggle('hidden');
        menuBtn.setAttribute('aria-expanded', String(isOpen));
      });
    }

    // Back to top button
    const backToTop = document.getElementById('backToTop');
    if (backToTop) {
      let ticking = false;
      window.addEventListener('scroll', () => {
        if (!ticking) {
          window.requestAnimationFrame(() => {
            if (window.scrollY > 400) {
              backToTop.classList.remove('opacity-0', 'translate-y-4', 'pointer-events-none');
              backToTop.classList.add('opacity-100', 'translate-y-0', 'pointer-events-auto');
            } else {
              backToTop.classList.add('opacity-0', 'translate-y-4', 'pointer-events-none');
              backToTop.classList.remove('opacity-100', 'translate-y-0', 'pointer-events-auto');
            }
            ticking = false;
          });
          ticking = true;
        }
      });

      backToTop.addEventListener('click', () => {
        window.scrollTo({ top: 0, behavior: 'smooth' });
      });
    }
  </script>
</body>
</html>
