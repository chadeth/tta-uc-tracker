---
import '../styles/global.css';

interface Props {
  title?: string;
  description?: string;
  currentPath?: string;
}

const {
  title = 'TTA-UC Research Tracker',
  description = 'Expert-level research intelligence on Triplet-Triplet Annihilation Upconversion. Tracking breakthroughs in fundamental mechanisms, materials design, and emerging applications.',
  currentPath = '/',
} = Astro.props;

const fullTitle = title === 'TTA-UC Research Tracker' ? title : `${title} | TTA-UC Research Tracker`;

const navLinks = [
  { href: '/', label: 'Home' },
  { href: '/catalog', label: 'Catalog' },
  { href: '/discussion', label: 'Discussion' },
  { href: '/about', label: 'About' },
];

function isActive(href: string, current: string): boolean {
  if (href === '/') return current === '/';
  return current.startsWith(href);
}
---

<!DOCTYPE html>
<html lang="en" class="dark">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>{fullTitle}</title>
  <meta name="description" content={description}>
  <link rel="icon" href="/favicon.svg" type="image/svg+xml">
  <link rel="icon" href="/favicon.ico" sizes="32x32">
  <link rel="canonical" href={`https://tta-uc-tracker.pages.dev${currentPath}`}>

  <!-- Open Graph -->
  <meta property="og:type" content="website">
  <meta property="og:title" content={fullTitle}>
  <meta property="og:description" content={description}>
  <meta property="og:site_name" content="TTA-UC Research Tracker">
  <meta property="og:url" content={`https://tta-uc-tracker.pages.dev${currentPath}`}>

  <!-- Twitter -->
  <meta name="twitter:card" content="summary_large_image">
  <meta name="twitter:title" content={fullTitle}>
  <meta name="twitter:description" content={description}>
</head>
<body class="bg-[var(--color-surface-0)] text-[var(--color-text-secondary)] font-sans antialiased min-h-screen flex flex-col">

  <!-- Subtle top accent line -->
  <div class="h-px w-full bg-gradient-to-r from-transparent via-[var(--color-accent)] to-transparent opacity-40"></div>

  <!-- Navigation -->
  <nav class="sticky top-0 z-50 backdrop-blur-xl bg-[var(--color-surface-0)]/80 border-b border-[var(--color-border-subtle)]">
    <div class="max-w-6xl mx-auto px-6 h-14 flex items-center justify-between">
      <a href="/" class="flex items-center gap-3 group">
        <div class="w-2 h-2 rounded-full bg-[var(--color-accent)] group-hover:shadow-[0_0_8px_var(--color-accent)] transition-shadow duration-300"></div>
        <span class="text-sm font-semibold text-[var(--color-text-primary)] tracking-tight">TTA-UC Research</span>
      </a>

      <!-- Desktop Nav -->
      <div class="hidden sm:flex items-center gap-1">
        {navLinks.map(link => (
          <a
            href={link.href}
            class:list={[
              'px-3.5 py-1.5 rounded-lg text-xs font-medium transition-all duration-200',
              isActive(link.href, currentPath)
                ? 'text-[var(--color-text-primary)] bg-[var(--color-surface-2)]'
                : 'text-[var(--color-text-tertiary)] hover:text-[var(--color-text-secondary)] hover:bg-[var(--color-surface-1)]',
            ]}
          >
            {link.label}
          </a>
        ))}
      </div>

      <!-- Mobile Nav Toggle -->
      <button
        id="mobileMenuBtn"
        class="sm:hidden flex flex-col gap-1 p-2 -mr-2"
        aria-label="Toggle menu"
      >
        <span class="w-4 h-px bg-[var(--color-text-tertiary)] transition-transform duration-200" id="menuLine1"></span>
        <span class="w-4 h-px bg-[var(--color-text-tertiary)] transition-opacity duration-200" id="menuLine2"></span>
        <span class="w-4 h-px bg-[var(--color-text-tertiary)] transition-transform duration-200" id="menuLine3"></span>
      </button>
    </div>

    <!-- Mobile Nav Menu -->
    <div id="mobileMenu" class="hidden sm:hidden border-t border-[var(--color-border-subtle)] bg-[var(--color-surface-0)]/95 backdrop-blur-xl">
      <div class="max-w-6xl mx-auto px-6 py-3 flex flex-col gap-1">
        {navLinks.map(link => (
          <a
            href={link.href}
            class:list={[
              'px-4 py-2.5 rounded-lg text-sm font-medium transition-all duration-200',
              isActive(link.href, currentPath)
                ? 'text-[var(--color-text-primary)] bg-[var(--color-surface-2)]'
                : 'text-[var(--color-text-tertiary)] hover:text-[var(--color-text-secondary)] hover:bg-[var(--color-surface-1)]',
            ]}
          >
            {link.label}
          </a>
        ))}
      </div>
    </div>
  </nav>

  <!-- Main Content -->
  <main class="flex-1">
    <slot />
  </main>

  <!-- Footer -->
  <footer class="border-t border-[var(--color-border-subtle)] bg-[var(--color-surface-0)]">
    <div class="max-w-6xl mx-auto px-6 py-12">
      <div class="grid grid-cols-1 sm:grid-cols-3 gap-8 mb-10">
        <!-- Brand -->
        <div>
          <div class="flex items-center gap-3 mb-4">
            <div class="w-2 h-2 rounded-full bg-[var(--color-accent)]"></div>
            <span class="text-sm font-semibold text-[var(--color-text-primary)] tracking-tight">TTA-UC Research</span>
          </div>
          <p class="text-xs text-[var(--color-text-tertiary)] leading-relaxed max-w-xs">
            Expert research intelligence on Triplet-Triplet Annihilation Upconversion, serving the global photochemistry community.
          </p>
        </div>

        <!-- Navigation -->
        <div>
          <h4 class="text-xs font-semibold text-[var(--color-text-primary)] uppercase tracking-wider mb-4">Navigate</h4>
          <div class="flex flex-col gap-2">
            {navLinks.map(link => (
              <a href={link.href} class="text-xs text-[var(--color-text-tertiary)] hover:text-[var(--color-text-secondary)] transition-colors duration-200">
                {link.label}
              </a>
            ))}
          </div>
        </div>

        <!-- Info -->
        <div>
          <h4 class="text-xs font-semibold text-[var(--color-text-primary)] uppercase tracking-wider mb-4">Resources</h4>
          <div class="flex flex-col gap-2">
            <a href="/catalog" class="text-xs text-[var(--color-text-tertiary)] hover:text-[var(--color-text-secondary)] transition-colors duration-200">Paper Database</a>
            <a href="/discussion" class="text-xs text-[var(--color-text-tertiary)] hover:text-[var(--color-text-secondary)] transition-colors duration-200">Research Commentary</a>
            <a href="/about" class="text-xs text-[var(--color-text-tertiary)] hover:text-[var(--color-text-secondary)] transition-colors duration-200">Methodology</a>
          </div>
        </div>
      </div>

      <div class="pt-8 border-t border-[var(--color-border-subtle)] flex flex-col sm:flex-row items-center justify-between gap-4">
        <span class="text-xs text-[var(--color-text-tertiary)]">Copyright 2026 TTA-UC Research Tracker. All rights reserved.</span>
        <span class="text-xs text-[var(--color-text-tertiary)]">Research intelligence for the photochemistry community</span>
      </div>
    </div>
  </footer>

  <!-- Mobile Menu Script -->
  <script is:inline>
    const menuBtn = document.getElementById('mobileMenuBtn');
    const mobileMenu = document.getElementById('mobileMenu');
    const line1 = document.getElementById('menuLine1');
    const line2 = document.getElementById('menuLine2');
    const line3 = document.getElementById('menuLine3');
    let menuOpen = false;

    if (menuBtn && mobileMenu) {
      menuBtn.addEventListener('click', () => {
        menuOpen = !menuOpen;
        mobileMenu.classList.toggle('hidden', !menuOpen);
        if (menuOpen) {
          line1.style.transform = 'rotate(45deg) translate(2px, 2px)';
          line2.style.opacity = '0';
          line3.style.transform = 'rotate(-45deg) translate(2px, -2px)';
        } else {
          line1.style.transform = '';
          line2.style.opacity = '';
          line3.style.transform = '';
        }
      });
    }
  </script>
</body>
</html>
