---
import Layout from '../../layouts/Base.astro';
import { getCollection, render as renderEntry } from 'astro:content';
import { getReadingTime } from '../../utils/reading-time';

export async function getStaticPaths() {
  const articles = await getCollection('articles');
  const sorted = [...articles].sort((a, b) =>
    new Date(b.data.date + 'T12:00:00').getTime() - new Date(a.data.date + 'T12:00:00').getTime()
  );
  return sorted.map((article, i) => ({
    params: { slug: article.id },
    props: {
      article,
      prevArticle: sorted[i + 1] || null,
      nextArticle: sorted[i - 1] || null,
    },
  }));
}

const { article, prevArticle, nextArticle } = Astro.props;
const { Content } = await renderEntry(article);

const dateObj = new Date(article.data.date + 'T12:00:00');
const formattedDate = dateObj.toLocaleDateString('en-US', {
  year: 'numeric',
  month: 'long',
  day: 'numeric',
});
const readingTime = getReadingTime(article.body || '');
---

<Layout
  title={article.data.title}
  description={`${article.data.title}. Commentary on TTA-UC research developments.`}
  currentPath={`/discussion/${article.id}`}
>

  <article class="max-w-[65ch] mx-auto px-6 pt-16 sm:pt-20 pb-24">

    <div class="mb-10">
      <a href="/discussion" class="text-sm text-[var(--color-text-tertiary)] hover:text-[var(--color-text-secondary)] transition-colors">
        Back to discussion
      </a>
    </div>

    <header class="mb-12">
      {article.data.edition && (
        <p class="text-sm text-[var(--color-text-tertiary)] mb-3">{article.data.edition}</p>
      )}
      <h1 class="text-3xl font-bold tracking-tight text-[var(--color-text-primary)] leading-tight mb-4">
        {article.data.title}
      </h1>
      <div class="flex items-center gap-3 text-sm text-[var(--color-text-tertiary)]">
        <time>{formattedDate}</time>
        <span class="text-[var(--color-border-default)]">/</span>
        <span>{readingTime}</span>
      </div>
    </header>

    <div class="prose prose-lg max-w-none">
      <Content />
    </div>

    {(prevArticle || nextArticle) && (
      <nav class="mt-16 pt-8 border-t border-[var(--color-border-subtle)]" aria-label="Article navigation">
        <div class="flex items-stretch justify-between gap-6">
          {prevArticle ? (
            <a
              href={`/discussion/${prevArticle.id}`}
              class="group flex flex-col items-start min-w-0 max-w-[48%]"
            >
              <span class="text-xs text-[var(--color-text-tertiary)] mb-1.5 flex items-center gap-1">
                <svg class="w-3 h-3" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 19l-7-7 7-7" />
                </svg>
                Older
              </span>
              <span class="text-sm text-[var(--color-text-secondary)] group-hover:text-[var(--color-accent-hover)] transition-colors truncate w-full">
                {prevArticle.data.title}
              </span>
            </a>
          ) : (
            <div />
          )}
          {nextArticle ? (
            <a
              href={`/discussion/${nextArticle.id}`}
              class="group flex flex-col items-end min-w-0 max-w-[48%] text-right ml-auto"
            >
              <span class="text-xs text-[var(--color-text-tertiary)] mb-1.5 flex items-center gap-1">
                Newer
                <svg class="w-3 h-3" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5l7 7-7 7" />
                </svg>
              </span>
              <span class="text-sm text-[var(--color-text-secondary)] group-hover:text-[var(--color-accent-hover)] transition-colors truncate w-full">
                {nextArticle.data.title}
              </span>
            </a>
          ) : (
            <div />
          )}
        </div>
      </nav>
    )}

  </article>

</Layout>
