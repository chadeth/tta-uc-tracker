---
import Layout from '../layouts/Base.astro';
import { getCollection } from 'astro:content';
import { getReadingTime } from '../utils/reading-time';
import catalog from '../data/catalog.json';

const allArticles = await getCollection('articles');
const sortedArticles = allArticles.sort((a, b) =>
  new Date(b.data.date + 'T12:00:00').getTime() - new Date(a.data.date + 'T12:00:00').getTime()
);
const latestArticle = sortedArticles[0];

const journals = new Set(catalog.map(p => p.journal).filter(Boolean));

// Recent significant papers
const recentPapers = [...catalog]
  .sort((a, b) => new Date(b.date + 'T12:00:00').getTime() - new Date(a.date + 'T12:00:00').getTime())
  .filter(p => p.significance === 'very-high' || p.significance === 'high')
  .slice(0, 5);

const websiteJsonLd = {
  '@context': 'https://schema.org',
  '@type': 'WebSite',
  name: 'TTA-UC Research Tracker',
  url: 'https://tta-uc-tracker.pages.dev',
  description: 'A curated catalog and commentary service tracking research on Triplet-Triplet Annihilation Upconversion.',
  about: {
    '@type': 'Thing',
    name: 'Triplet-Triplet Annihilation Upconversion',
    sameAs: 'https://en.wikipedia.org/wiki/Photon_upconversion',
  },
  inLanguage: 'en',
};
---

<Layout title="TTA-UC Research Tracker" currentPath="/">
  <script slot="head" type="application/ld+json" set:html={JSON.stringify(websiteJsonLd)} />

  <div class="max-w-7xl mx-auto px-6">

    <!-- Header -->
    <section class="pt-16 sm:pt-24 pb-16 max-w-3xl">
      <h1 class="text-3xl sm:text-4xl font-bold tracking-tight text-[var(--color-text-primary)] leading-tight mb-6">
        TTA-UC Research Tracker
      </h1>
      <p class="text-[var(--color-text-secondary)] leading-relaxed text-lg mb-6">
        A curated catalog and commentary service tracking research on Triplet-Triplet Annihilation Upconversion. We monitor the literature, evaluate significance, and provide structured analysis for the photochemistry community.
      </p>
      <p class="text-sm text-[var(--color-text-tertiary)]">
        Currently tracking {catalog.length} papers across {journals.size} journals.
      </p>
    </section>

    <!-- Latest Discussion -->
    {latestArticle && (
      <section class="pb-16 border-t border-[var(--color-border-subtle)] pt-10">
        <h2 class="text-xs font-medium text-[var(--color-text-tertiary)] uppercase tracking-wider mb-6">Latest Discussion</h2>

        <div class="max-w-3xl">
          <a href={`/discussion/${latestArticle.id}`} class="group">
            <h3 class="text-xl font-semibold text-[var(--color-text-primary)] group-hover:text-[var(--color-accent-hover)] transition-colors mb-2">
              {latestArticle.data.title}
            </h3>
          </a>
          <div class="flex items-center gap-3 text-sm text-[var(--color-text-tertiary)] mb-4">
            <time>
              {new Date(latestArticle.data.date + 'T12:00:00').toLocaleDateString('en-US', { year: 'numeric', month: 'long', day: 'numeric' })}
            </time>
            {latestArticle.data.edition && (
              <>
                <span class="text-[var(--color-border-default)]">/</span>
                <span>{latestArticle.data.edition}</span>
              </>
            )}
            <span class="text-[var(--color-border-default)]">/</span>
            <span>{getReadingTime(latestArticle.body || '')}</span>
          </div>
          <p class="text-[var(--color-text-secondary)] leading-relaxed mb-4">
            In-depth analysis covering the latest TTA-UC publications, with commentary on significance, emerging patterns, and implications for researchers.
          </p>
          <a href={`/discussion/${latestArticle.id}`} class="text-sm text-[var(--color-accent-hover)] hover:text-[var(--color-accent)] transition-colors">
            Read full discussion
          </a>
        </div>
      </section>
    )}

    <!-- Recent Notable Papers -->
    {recentPapers.length > 0 && (
      <section class="pb-24 border-t border-[var(--color-border-subtle)] pt-10">
        <div class="flex items-baseline justify-between mb-6">
          <h2 class="text-xs font-medium text-[var(--color-text-tertiary)] uppercase tracking-wider">Notable Papers</h2>
          <a href="/catalog" class="text-sm text-[var(--color-text-tertiary)] hover:text-[var(--color-text-secondary)] transition-colors">
            View all
          </a>
        </div>

        <div class="divide-y divide-[var(--color-border-subtle)]">
          {recentPapers.map(paper => (
            <div class="py-5 first:pt-0 last:pb-0">
              <div class="flex items-start justify-between gap-6">
                <div class="min-w-0">
                  <a
                    href={paper.url || '#'}
                    target="_blank"
                    rel="noopener"
                    class="text-[var(--color-text-primary)] hover:text-[var(--color-accent-hover)] transition-colors font-medium leading-snug"
                  >
                    {paper.title}
                  </a>
                  <div class="flex flex-wrap items-center gap-x-2 gap-y-1 mt-2 text-sm text-[var(--color-text-tertiary)]">
                    <span class="truncate max-w-sm">
                      {paper.authors.slice(0, 3).join(', ')}{paper.authors.length > 3 ? ' et al.' : ''}
                    </span>
                    {paper.journal && (
                      <>
                        <span class="text-[var(--color-border-default)]">/</span>
                        <span>{paper.journal}</span>
                      </>
                    )}
                    <span class="text-[var(--color-border-default)]">/</span>
                    <time>
                      {new Date(paper.date + 'T12:00:00').toLocaleDateString('en-US', { year: 'numeric', month: 'short' })}
                    </time>
                  </div>
                </div>
                {paper.significance === 'very-high' && (
                  <span class="shrink-0 text-xs text-[var(--color-text-tertiary)] font-medium mt-1">
                    High impact
                  </span>
                )}
              </div>
            </div>
          ))}
        </div>
      </section>
    )}

  </div>

</Layout>
