---
import Layout from '../../layouts/Base.astro';
import { getCollection } from 'astro:content';

const allArticles = await getCollection('articles');
const sortedArticles = allArticles.sort((a, b) =>
  new Date(b.data.date + 'T12:00:00').getTime() - new Date(a.data.date + 'T12:00:00').getTime()
);
---

<Layout
  title="Discussion"
  description="Expert commentary and analysis on the latest Triplet-Triplet Annihilation Upconversion research. In-depth discussion of key publications, emerging trends, and field trajectory."
  currentPath="/discussion"
>

  <div class="max-w-7xl mx-auto px-6">

    <!-- Header -->
    <section class="pt-16 sm:pt-20 pb-12 animate-fade-in">
      <div class="flex items-center gap-3 mb-6">
        <div class="h-px w-12 bg-[var(--color-accent)]"></div>
        <span class="text-xs font-semibold text-[var(--color-accent-hover)] uppercase tracking-widest">Commentary</span>
      </div>

      <h1 class="text-3xl sm:text-4xl font-bold tracking-tight text-[var(--color-text-primary)] leading-tight mb-4">
        Research Discussion
      </h1>
      <p class="text-[var(--color-text-tertiary)] leading-relaxed max-w-3xl">
        Expert analysis and commentary on TTA-UC research developments. Each edition provides structured discussion of recent publications, identifies emerging trends, and evaluates industrial implications.
      </p>
    </section>

    <!-- Articles List -->
    <section class="pb-24 animate-fade-in" style="animation-delay: 0.1s">
      {sortedArticles.length === 0 ? (
        <div class="text-center py-20">
          <p class="text-[var(--color-text-tertiary)] text-lg">No discussion articles yet. Check back soon.</p>
        </div>
      ) : (
        <div class="space-y-4">
          {sortedArticles.map((article, index) => {
            const dateObj = new Date(article.data.date + 'T12:00:00');
            const formattedDate = dateObj.toLocaleDateString('en-US', {
              year: 'numeric',
              month: 'long',
              day: 'numeric'
            });
            const isLatest = index === 0;

            return (
              <a
                href={`/discussion/${article.id}`}
                class="block group rounded-2xl border border-[var(--color-border-subtle)] bg-[var(--color-surface-1)] overflow-hidden transition-lift hover:border-[var(--color-border-default)]"
              >
                <div class="p-8 sm:p-10">
                  <div class="flex items-start justify-between gap-4 mb-4">
                    <div class="flex items-center gap-3">
                      {isLatest && (
                        <span class="px-2.5 py-0.5 rounded-full text-[10px] font-bold uppercase tracking-wider bg-[var(--color-accent)]/15 text-[var(--color-accent-hover)] border border-[var(--color-accent)]/20">
                          Latest
                        </span>
                      )}
                      {article.data.edition && (
                        <span class="text-xs text-[var(--color-accent-hover)] font-medium">{article.data.edition}</span>
                      )}
                    </div>
                    <time class="text-xs text-[var(--color-text-tertiary)] tabular-nums whitespace-nowrap">
                      {formattedDate}
                    </time>
                  </div>

                  <h2 class="text-xl sm:text-2xl font-bold text-[var(--color-text-primary)] leading-snug group-hover:text-[var(--color-accent-hover)] transition-colors duration-200 mb-4">
                    {article.data.title}
                  </h2>

                  <p class="text-[var(--color-text-tertiary)] leading-relaxed mb-6">
                    Comprehensive analysis covering the latest TTA-UC publications, with expert commentary on significance, emerging patterns, and implications for researchers and industry professionals.
                  </p>

                  <span class="inline-flex items-center gap-2 text-sm font-medium text-[var(--color-accent-hover)] group-hover:gap-3 transition-all duration-200">
                    Read full discussion
                    <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17 8l4 4m0 0l-4 4m4-4H3" /></svg>
                  </span>
                </div>
              </a>
            );
          })}
        </div>
      )}
    </section>

  </div>

</Layout>
