---
import Layout from '../../layouts/Base.astro';
import { getCollection, render as renderEntry } from 'astro:content';
import { getReadingTime } from '../../utils/reading-time';

export async function getStaticPaths() {
  const articles = await getCollection('articles');
  const sorted = [...articles].sort((a, b) =>
    new Date(b.data.date + 'T12:00:00').getTime() - new Date(a.data.date + 'T12:00:00').getTime()
  );
  return sorted.map((article, i) => ({
    params: { slug: article.id },
    props: {
      article,
      prevArticle: sorted[i + 1] || null,
      nextArticle: sorted[i - 1] || null,
    },
  }));
}

const { article, prevArticle, nextArticle } = Astro.props;
const { Content } = await renderEntry(article);

const dateObj = new Date(article.data.date + 'T12:00:00');
const formattedDate = dateObj.toLocaleDateString('en-US', {
  year: 'numeric',
  month: 'long',
  day: 'numeric',
});
const readingTime = getReadingTime(article.body || '');
const isoDate = dateObj.toISOString().split('T')[0];

// Word count for structured data
const wordCount = (article.body || '').replace(/[#*_\[\]()>-]/g, '').split(/\s+/).filter(Boolean).length;

const jsonLd = {
  '@context': 'https://schema.org',
  '@type': 'Article',
  headline: article.data.title,
  datePublished: isoDate,
  dateModified: isoDate,
  description: `${article.data.title}. Commentary on TTA-UC research developments.`,
  wordCount: wordCount,
  url: `https://tta-uc-tracker.pages.dev/discussion/${article.id}`,
  mainEntityOfPage: {
    '@type': 'WebPage',
    '@id': `https://tta-uc-tracker.pages.dev/discussion/${article.id}`,
  },
  publisher: {
    '@type': 'Organization',
    name: 'TTA-UC Research Tracker',
    url: 'https://tta-uc-tracker.pages.dev',
  },
  isPartOf: {
    '@type': 'WebSite',
    name: 'TTA-UC Research Tracker',
    url: 'https://tta-uc-tracker.pages.dev',
  },
  about: {
    '@type': 'Thing',
    name: 'Triplet-Triplet Annihilation Upconversion',
    sameAs: 'https://en.wikipedia.org/wiki/Photon_upconversion',
  },
  inLanguage: 'en',
};
---

<Layout
  title={article.data.title}
  description={`${article.data.title}. Commentary on TTA-UC research developments.`}
  currentPath={`/discussion/${article.id}`}
>
  <script slot="head" type="application/ld+json" set:html={JSON.stringify(jsonLd)} />

  <article class="max-w-[65ch] mx-auto px-6 pt-16 sm:pt-20 pb-24">

    <div class="mb-10">
      <a href="/discussion" class="text-sm text-[var(--color-text-tertiary)] hover:text-[var(--color-text-secondary)] transition-colors">
        Back to discussion
      </a>
    </div>

    <header class="mb-12">
      {article.data.edition && (
        <p class="text-sm text-[var(--color-text-tertiary)] mb-3">{article.data.edition}</p>
      )}
      <h1 class="text-3xl font-bold tracking-tight text-[var(--color-text-primary)] leading-tight mb-4">
        {article.data.title}
      </h1>
      <div class="flex items-center gap-3 text-sm text-[var(--color-text-tertiary)]">
        <time>{formattedDate}</time>
        <span class="text-[var(--color-border-default)]">/</span>
        <span>{readingTime}</span>
      </div>
    </header>

    <!-- Table of Contents (auto-generated from h2 headings) -->
    <nav id="toc" class="hidden mb-12 py-5 px-6 rounded-lg bg-[var(--color-surface-1)] border border-[var(--color-border-subtle)]" aria-label="Table of contents">
      <p class="text-xs font-medium text-[var(--color-text-tertiary)] uppercase tracking-wider mb-3">Contents</p>
    </nav>

    <div class="prose prose-lg max-w-none">
      <Content />
    </div>

    {(prevArticle || nextArticle) && (
      <nav class="mt-16 pt-8 border-t border-[var(--color-border-subtle)]" aria-label="Article navigation">
        <div class="flex items-stretch justify-between gap-6">
          {prevArticle ? (
            <a
              href={`/discussion/${prevArticle.id}`}
              class="group flex flex-col items-start min-w-0 max-w-[48%]"
            >
              <span class="text-xs text-[var(--color-text-tertiary)] mb-1.5 flex items-center gap-1">
                <svg class="w-3 h-3" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 19l-7-7 7-7" />
                </svg>
                Older
              </span>
              <span class="text-sm text-[var(--color-text-secondary)] group-hover:text-[var(--color-accent-hover)] transition-colors truncate w-full">
                {prevArticle.data.title}
              </span>
            </a>
          ) : (
            <div />
          )}
          {nextArticle ? (
            <a
              href={`/discussion/${nextArticle.id}`}
              class="group flex flex-col items-end min-w-0 max-w-[48%] text-right ml-auto"
            >
              <span class="text-xs text-[var(--color-text-tertiary)] mb-1.5 flex items-center gap-1">
                Newer
                <svg class="w-3 h-3" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5l7 7-7 7" />
                </svg>
              </span>
              <span class="text-sm text-[var(--color-text-secondary)] group-hover:text-[var(--color-accent-hover)] transition-colors truncate w-full">
                {nextArticle.data.title}
              </span>
            </a>
          ) : (
            <div />
          )}
        </div>
      </nav>
    )}

  </article>

  <script is:inline>
    // Auto-generate table of contents from h2 headings
    const prose = document.querySelector('.prose');
    const tocContainer = document.getElementById('toc');
    if (prose && tocContainer) {
      const headings = prose.querySelectorAll('h2');
      if (headings.length >= 2) {
        headings.forEach(function(h, i) {
          if (!h.id) {
            h.id = h.textContent
              .trim()
              .toLowerCase()
              .replace(/[^a-z0-9]+/g, '-')
              .replace(/^-|-$/g, '') || ('section-' + i);
          }
        });

        const list = document.createElement('ol');
        list.className = 'space-y-1.5 text-sm list-decimal list-inside';
        headings.forEach(function(h) {
          const li = document.createElement('li');
          li.className = 'text-[var(--color-text-tertiary)]';
          const a = document.createElement('a');
          a.href = '#' + h.id;
          a.textContent = h.textContent.trim();
          a.className = 'hover:text-[var(--color-accent-hover)] transition-colors';
          a.style.color = 'inherit';
          li.appendChild(a);
          list.appendChild(li);
        });

        tocContainer.appendChild(list);
        tocContainer.classList.remove('hidden');
      }
    }
  </script>

</Layout>
