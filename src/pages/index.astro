---
import Layout from '../layouts/Base.astro';
import { getCollection } from 'astro:content';
import catalog from '../data/catalog.json';

const allArticles = await getCollection('articles');
const sortedArticles = allArticles.sort((a, b) =>
  new Date(b.data.date + 'T12:00:00').getTime() - new Date(a.data.date + 'T12:00:00').getTime()
);
const latestArticle = sortedArticles[0];

// Stats
const journals = new Set(catalog.map(p => p.journal).filter(Boolean));
const highImpact = catalog.filter(p => p.significance === 'high' || p.significance === 'very-high').length;
const dates = catalog.map(p => new Date(p.date + 'T12:00:00')).sort((a, b) => a.getTime() - b.getTime());
const newestDate = dates[dates.length - 1].toLocaleDateString('en-US', { month: 'short', year: 'numeric' });

// Featured paper (highest significance, most recent)
const featured = catalog
  .filter(p => p.significance === 'very-high')
  .sort((a, b) => new Date(b.date + 'T12:00:00').getTime() - new Date(a.date + 'T12:00:00').getTime())[0]
  || catalog[0];

// Category counts
const categoryNames = {
  'fundamental-mechanism': 'Fundamental Mechanism',
  'materials-design': 'Materials Design',
  'application': 'Application',
  'review-perspective': 'Review & Perspective',
  'review': 'Review',
  'computational': 'Computational',
};
const categoryCounts = {} as Record<string, number>;
catalog.forEach(paper => {
  const displayCat = categoryNames[paper.category] || paper.category;
  categoryCounts[displayCat] = (categoryCounts[displayCat] || 0) + 1;
});
---

<Layout title="TTA-UC Research Tracker" currentPath="/" description="Expert-level research intelligence on Triplet-Triplet Annihilation Upconversion. Curated analysis of breakthroughs in fundamental mechanisms, materials design, and applications.">

  <!-- Hero -->
  <section class="relative overflow-hidden">
    <!-- Background gradient orbs -->
    <div class="absolute inset-0 overflow-hidden pointer-events-none">
      <div class="absolute -top-40 -right-40 w-96 h-96 bg-[var(--color-accent)] rounded-full opacity-[0.03] blur-3xl"></div>
      <div class="absolute top-60 -left-40 w-80 h-80 bg-purple-500 rounded-full opacity-[0.02] blur-3xl"></div>
    </div>

    <div class="max-w-7xl mx-auto px-6 pt-24 sm:pt-32 pb-20">
      <div class="max-w-4xl animate-fade-in">
        <div class="flex items-center gap-3 mb-8">
          <div class="h-px w-12 bg-[var(--color-accent)]"></div>
          <span class="text-xs font-semibold text-[var(--color-accent-hover)] uppercase tracking-widest">Research Intelligence</span>
        </div>

        <h1 class="text-4xl sm:text-5xl lg:text-6xl font-bold tracking-tight gradient-text leading-[1.1] mb-8">
          Triplet-Triplet Annihilation Upconversion
        </h1>

        <p class="text-lg sm:text-xl text-[var(--color-text-tertiary)] leading-relaxed max-w-3xl mb-12">
          Tracking and analyzing the frontier of photon upconversion research. Expert commentary, curated catalogs, and structured intelligence for researchers and industry professionals.
        </p>

        <div class="flex flex-wrap gap-4">
          <a href="/catalog" class="inline-flex items-center gap-2 px-6 py-3 rounded-xl bg-[var(--color-accent)] text-white text-sm font-semibold hover:bg-[var(--color-accent-hover)] transition-all duration-200 hover:shadow-[0_0_24px_var(--color-accent-muted)]">
            Explore Catalog
            <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17 8l4 4m0 0l-4 4m4-4H3" /></svg>
          </a>
          <a href="/discussion" class="inline-flex items-center gap-2 px-6 py-3 rounded-xl border border-[var(--color-border-default)] text-[var(--color-text-secondary)] text-sm font-semibold hover:border-[var(--color-accent)] hover:text-[var(--color-text-primary)] transition-all duration-200">
            Read Discussion
          </a>
        </div>
      </div>
    </div>
  </section>

  <!-- Stats -->
  <section class="max-w-7xl mx-auto px-6 pb-20 animate-fade-in" style="animation-delay: 0.1s">
    <div class="grid grid-cols-2 sm:grid-cols-4 gap-3 sm:gap-4">
      <div class="group rounded-xl border border-[var(--color-border-subtle)] bg-[var(--color-surface-1)] p-5 transition-lift cursor-default">
        <div class="text-xs font-medium text-[var(--color-text-tertiary)] uppercase tracking-wider mb-2">Papers Tracked</div>
        <div class="text-3xl font-bold text-[var(--color-text-primary)] tabular-nums">{catalog.length}</div>
      </div>
      <div class="group rounded-xl border border-[var(--color-border-subtle)] bg-[var(--color-surface-1)] p-5 transition-lift cursor-default">
        <div class="text-xs font-medium text-[var(--color-text-tertiary)] uppercase tracking-wider mb-2">Journals</div>
        <div class="text-3xl font-bold text-[var(--color-text-primary)] tabular-nums">{journals.size}</div>
      </div>
      <div class="group rounded-xl border border-[var(--color-border-subtle)] bg-[var(--color-surface-1)] p-5 transition-lift cursor-default">
        <div class="text-xs font-medium text-[var(--color-text-tertiary)] uppercase tracking-wider mb-2">High Impact</div>
        <div class="text-3xl font-bold text-[var(--color-accent-hover)] tabular-nums">{highImpact}</div>
      </div>
      <div class="group rounded-xl border border-[var(--color-border-subtle)] bg-[var(--color-surface-1)] p-5 transition-lift cursor-default">
        <div class="text-xs font-medium text-[var(--color-text-tertiary)] uppercase tracking-wider mb-2">Categories</div>
        <div class="text-3xl font-bold text-[var(--color-text-primary)] tabular-nums">{Object.keys(categoryCounts).length}</div>
      </div>
    </div>
  </section>

  <!-- Featured Paper -->
  {featured && (
    <section class="max-w-7xl mx-auto px-6 pb-20 animate-fade-in" style="animation-delay: 0.15s">
      <div class="flex items-center gap-4 mb-8">
        <h2 class="text-xl font-semibold text-[var(--color-text-primary)] tracking-tight">Featured Research</h2>
        <div class="flex-1 h-px bg-[var(--color-border-subtle)]"></div>
      </div>

      <div class="rounded-2xl border border-[var(--color-border-subtle)] bg-[var(--color-surface-1)] overflow-hidden group hover:border-[var(--color-border-default)] transition-all duration-300">
        <div class="p-8 sm:p-10">
          <div class="flex items-start justify-between gap-4 mb-4">
            <div class="flex items-center gap-3">
              {featured.significance === 'very-high' && (
                <span class="px-2.5 py-0.5 rounded-full text-[10px] font-bold uppercase tracking-wider bg-[var(--color-rose)]/15 text-[var(--color-rose)] border border-[var(--color-rose)]/20">
                  Top Paper
                </span>
              )}
              {featured.journal && (
                <span class="text-xs text-[var(--color-accent-hover)] font-medium">{featured.journal}</span>
              )}
            </div>
            <time class="text-xs text-[var(--color-text-tertiary)] tabular-nums">
              {new Date(featured.date + 'T12:00:00').toLocaleDateString('en-US', { year: 'numeric', month: 'long' })}
            </time>
          </div>

          <a href={featured.url || '#'} target="_blank" rel="noopener" class="block mb-4">
            <h3 class="text-xl sm:text-2xl font-bold text-[var(--color-text-primary)] leading-snug hover:text-[var(--color-accent-hover)] transition-colors duration-200">
              {featured.title}
              <svg class="inline-block w-4 h-4 ml-2 opacity-0 group-hover:opacity-50 transition-opacity duration-200" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M10 6H6a2 2 0 00-2 2v10a2 2 0 002 2h10a2 2 0 002-2v-4M14 4h6m0 0v6m0-6L10 14" />
              </svg>
            </h3>
          </a>

          <p class="text-sm text-[var(--color-text-tertiary)] mb-5">
            {featured.authors.slice(0, 4).join(', ')}{featured.authors.length > 4 ? ` +${featured.authors.length - 4}` : ''}
          </p>

          <p class="text-[var(--color-text-secondary)] leading-relaxed mb-6">
            {featured.abstract_summary}
          </p>

          {featured.significance_notes && (
            <div class="rounded-lg bg-[var(--color-surface-0)] border border-[var(--color-border-subtle)] px-5 py-4">
              <div class="flex items-center gap-2 mb-2">
                <div class="w-1 h-1 rounded-full bg-[var(--color-accent)]"></div>
                <span class="text-[10px] font-semibold uppercase tracking-wider text-[var(--color-text-tertiary)]">Why It Matters</span>
              </div>
              <p class="text-sm text-[var(--color-text-secondary)] leading-relaxed">{featured.significance_notes}</p>
            </div>
          )}
        </div>
      </div>
    </section>
  )}

  <!-- Latest Discussion -->
  {latestArticle && (
    <section class="max-w-7xl mx-auto px-6 pb-20 animate-fade-in" style="animation-delay: 0.2s">
      <div class="flex items-center gap-4 mb-8">
        <h2 class="text-xl font-semibold text-[var(--color-text-primary)] tracking-tight">Latest Discussion</h2>
        <div class="flex-1 h-px bg-[var(--color-border-subtle)]"></div>
        <a href="/discussion" class="text-xs text-[var(--color-accent-hover)] hover:text-[var(--color-accent)] font-medium transition-colors duration-200">View all</a>
      </div>

      <a href={`/discussion/${latestArticle.id}`} class="block rounded-2xl border border-[var(--color-border-subtle)] bg-[var(--color-surface-1)] p-8 sm:p-10 group hover:border-[var(--color-border-default)] transition-all duration-300">
        <div class="flex items-start justify-between gap-4 mb-4">
          {latestArticle.data.edition && (
            <span class="text-xs text-[var(--color-accent-hover)] font-semibold">{latestArticle.data.edition}</span>
          )}
          <time class="text-xs text-[var(--color-text-tertiary)] tabular-nums">
            {new Date(latestArticle.data.date + 'T12:00:00').toLocaleDateString('en-US', { year: 'numeric', month: 'long', day: 'numeric' })}
          </time>
        </div>

        <h3 class="text-xl sm:text-2xl font-bold text-[var(--color-text-primary)] leading-snug group-hover:text-[var(--color-accent-hover)] transition-colors duration-200 mb-4">
          {latestArticle.data.title}
        </h3>

        <p class="text-[var(--color-text-tertiary)] leading-relaxed mb-6">
          In-depth analysis and commentary on the latest developments in TTA-UC research, covering key publications, emerging trends, and industrial implications.
        </p>

        <span class="inline-flex items-center gap-2 text-sm font-medium text-[var(--color-accent-hover)] group-hover:gap-3 transition-all duration-200">
          Read full discussion
          <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17 8l4 4m0 0l-4 4m4-4H3" /></svg>
        </span>
      </a>
    </section>
  )}

  <!-- Research Categories -->
  <section class="max-w-7xl mx-auto px-6 pb-24 animate-fade-in" style="animation-delay: 0.25s">
    <div class="flex items-center gap-4 mb-8">
      <h2 class="text-xl font-semibold text-[var(--color-text-primary)] tracking-tight">Research Areas</h2>
      <div class="flex-1 h-px bg-[var(--color-border-subtle)]"></div>
    </div>

    <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 gap-4">
      {Object.entries(categoryCounts).sort((a, b) => b[1] - a[1]).map(([cat, count]) => {
        const icons = {
          'Fundamental Mechanism': '🔬',
          'Materials Design': '🧪',
          'Application': '⚡',
          'Review & Perspective': '📖',
          'Review': '📖',
          'Computational': '💻',
        };
        return (
          <a href={`/catalog?category=${encodeURIComponent(cat)}`} class="group rounded-xl border border-[var(--color-border-subtle)] bg-[var(--color-surface-1)] p-6 transition-lift hover:border-[var(--color-border-default)]">
            <div class="flex items-center justify-between mb-3">
              <span class="text-2xl">{icons[cat] || '📄'}</span>
              <span class="text-xs text-[var(--color-text-tertiary)] tabular-nums font-medium">{count} papers</span>
            </div>
            <h3 class="text-sm font-semibold text-[var(--color-text-primary)] group-hover:text-[var(--color-accent-hover)] transition-colors duration-200">{cat}</h3>
          </a>
        );
      })}
    </div>
  </section>

</Layout>
